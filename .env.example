# 服务配置
PORT=3003
FRONTEND_URL=http://localhost:9090
NODE_ENV=development
JWT_SECRET=change-me-in-production

# 数据库驱动
# sqlite  - 本地开发，全部使用 SQLite（默认）
# hybrid  - 系统表 SQLite，直播订单 MySQL data_analysis
# mysql   - 系统表 MySQL rehot；订单库由 MYSQL_ORDERS_DATABASE 决定：
#             配置为 data_analysis 时，sys_tb_order 走独立订单库（推荐对接生产）
#             不配置 MYSQL_ORDERS_DATABASE 时，订单与应用同在 rehot 库
DB_DRIVER=sqlite

# SQLite（DB_DRIVER=sqlite 或 hybrid 时生效）
# SQLITE_FILE=server/data/rehot.db

# MySQL 连接
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=rehot
# mysql 模式下配置此项时，sys_tb_order 使用独立订单库（如生产 data_analysis）
MYSQL_ORDERS_DATABASE=data_analysis
MYSQL_CONNECTION_LIMIT=10
